{
  "name": "artisan-roast",
  "version": "0.100.3",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build-resilient.js",
    "build:no-migrate": "node scripts/build-resilient.js --no-migrate",
    "vercel-build": "DATABASE_URL=$DIRECT_URL PRISMA_MIGRATE_ADVISORY_LOCK_TIMEOUT=180000 node scripts/build-resilient.js",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "start": "next start",
    "lint": "eslint",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"!node_modules\"",
    "typecheck": "tsc --noEmit",
    "precheck": "npm run typecheck && npm run lint",
    "check:backup-models": "node -e \"const { execSync } = require('child_process'); const fs = require('fs'); const script = 'dev-tools/check-backup-models.ts'; if (fs.existsSync(script)) { execSync('npx tsx ' + script, { stdio: 'inherit' }); } else { console.log('Skipping backup model check (', script, 'not present).'); }\"",
    "seed": "tsx prisma/seed/index.ts",
    "qa:install": "node scripts/qa-agent.js",
    "qa:teardown": "node scripts/qa-teardown.js",
    "qa:reset": "node scripts/qa-reset.js",
    "reset:demo": "tsx scripts/reset-demo-data.ts",
    "build:safe": "npm run check:backup-models && npm run db:backup && npm run build",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:pre-pr": "npm run precheck && npm run test:ci && npm run test:e2e",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:restore": "tsx scripts/restore-database.ts",
    "db:safe-migrate": "tsx scripts/safe-migrate.ts",
    "db:smoke": "tsx scripts/smoke-crud.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "setup": "tsx scripts/setup.ts",
    "upgrade": "tsx scripts/upgrade.ts",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major",
    "theme:add": "tsx scripts/add-theme.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
