# ==============================================
# DATABASE (Neon PostgreSQL)
# ==============================================
# Pooled connection (for app runtime - fast but can't run migrations)
# Add connection_limit and pool_timeout for better reliability
DATABASE_URL="postgresql://user:password@host-pooler.region.neon.tech/dbname?sslmode=require&connection_limit=10&pool_timeout=30"

# Direct connection (for migrations - slower but can acquire locks)
# Remove "-pooler" from hostname to get direct connection
# Add connect_timeout for better resilience during builds
DIRECT_URL="postgresql://user:password@host.region.neon.tech/dbname?sslmode=require&connect_timeout=30"

# ==============================================
# AI PROVIDER (OpenAI-compatible)
# ==============================================
# Any OpenAI-compatible provider works: OpenAI, Gemini, Groq, Ollama, etc.
# These are fallbacks — prefer configuring via Settings > AI in the admin panel.
# AI_BASE_URL="https://api.openai.com/v1"
# AI_API_KEY="your_api_key_here"
# AI_MODEL="gpt-4o-mini"

# ==============================================
# GROK AI (Image Generation)
# ==============================================
# Get your API key from: https://x.ai/api
# Used for generating product images
GROK_API_KEY="your_grok_api_key_here"

# ==============================================
# UNSPLASH (Placeholder Images)
# ==============================================
# Get your API key from: https://unsplash.com/developers
# Used for fetching placeholder image URLs (dev-tools script only)
# This is only needed to run: npx tsx dev-tools/fetch-unsplash-images.ts
UNSPLASH_ACCESS_KEY="your_unsplash_access_key_here"

# ==============================================
# STRIPE (Payment Processing)
# ==============================================
# Test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret for local development (from Stripe CLI)
# Run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==============================================
# AUTH.JS (Authentication)
# ==============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your_random_32_byte_string_here"

# ==============================================
# GOOGLE OAUTH
# ==============================================
# Setup: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your_google_client_id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-your_google_client_secret"

# ==============================================
# GITHUB OAUTH
# ==============================================
# Setup: https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your_github_client_id"
AUTH_GITHUB_SECRET="your_github_client_secret"

# ==============================================
# GITHUB FEEDBACK INTEGRATION (Optional)
# ==============================================
# Used by the in-app feedback widget to create GitHub Issues
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scope: "repo" (for private repos) or "public_repo" (for public repos)
GITHUB_TOKEN="github_pat_..."
GITHUB_REPO_OWNER="yuens1002"
GITHUB_REPO_NAME="artisan-roast"

# ==============================================
# RESEND (Transactional Emails)
# ==============================================
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
RESEND_API_KEY="re_..."

# Email addresses
# For development: use onboarding@resend.dev (no domain verification needed)
# For production: verify your domain or single email address at https://resend.com/domains
RESEND_FROM_EMAIL="Artisan Roast <onboarding@resend.dev>"
# Your real email address for merchant notifications (must be your Resend account email in dev)
RESEND_MERCHANT_EMAIL="your-email@gmail.com"

# ==============================================
# VAPI (Voice AI) — Demo only, not for self-hosted
# ==============================================
# Only used on the live demo site (NEXT_PUBLIC_DEMO_MODE=true).
# Self-hosters can ignore these.
# NEXT_PUBLIC_VAPI_PUBLIC_KEY="your_vapi_public_key_here"
# NEXT_PUBLIC_VAPI_WEBHOOK_SECRET="your-vapi-webhook-secret-here"

# ==============================================
# CRON (Scheduled Jobs)
# ==============================================
# Secret token for authenticating cron endpoints (e.g., review request emails)
# Generate with: openssl rand -base64 32
# Set in Vercel dashboard > Settings > Environment Variables
CRON_SECRET="your_cron_secret_here"

# ==============================================
# APP CONFIGURATION
# ==============================================
# Your app's public URL (for email links and redirects)
# Development: http://localhost:3000
# Production: https://your-app.vercel.app (set in Vercel dashboard > Settings > Environment Variables)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Log level for server-side logging (debug | info | warn | error)
# Default: info (skips debug messages)
# Set to "debug" locally when troubleshooting webhooks
# LOG_LEVEL="info"

# ==============================================
# DEMO MODE (Optional)
# ==============================================
# Set to "true" to show demo credentials banner on the public site
# Only use this for public demo instances
# NEXT_PUBLIC_DEMO_MODE="true"

# ==============================================
# DEVELOPMENT ONLY
# ==============================================
# Set to "true" to view the /setup UI in development without wiping your admin.
# Only works when NODE_ENV=development. POST to /api/admin/setup remains protected.
# SETUP_PREVIEW="true"

# ==============================================
# ANALYTICS & SEO (Optional)
# ==============================================
# Google Analytics 4 - Measurement ID from: https://analytics.google.com/
# NEXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"

# Google Search Console - HTML tag verification code
# Get from: https://search.google.com/search-console → Add Property → HTML tag
# Copy only the "content" value from the meta tag
# NEXT_PUBLIC_GSC_VERIFICATION="your_verification_code"

# ==============================================
# VERCEL BLOB (Image Storage)
# ==============================================
# Get your token from: Vercel Dashboard > Storage > Blob > Manage > Tokens
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ==============================================
# TELEMETRY (Optional)
# ==============================================
# Anonymous usage tracking helps the maintainers understand platform adoption.
# See INSTALLATION.md > Telemetry for full details on what is collected.
# Set to "true" to disable all telemetry (env var takes highest priority)
# TELEMETRY_DISABLED="true"
# Override the default telemetry endpoint (for forks running their own server)
# TELEMETRY_ENDPOINT="https://your-server.com/api/telemetry/events"

# ==============================================
# ARTISAN ROAST PLATFORM (Pro/Trial License)
# ==============================================
# Leave blank for Free tier. Get a key at manage.artisanroast.app
# LICENSE_KEY=
# PLATFORM_URL=https://manage.artisanroast.app
# For development: override tier detection without a real platform
# MOCK_LICENSE_TIER=FREE

# ==============================================
# BUILD CONFIGURATION (Optional)
# ==============================================
# Set to "true" to automatically seed the database with minimal data during build
# Useful for one-click Vercel deploys to avoid empty database on first run
# SEED_ON_BUILD="true"

# ==============================================
# QA AGENT (Local testing only — never commit real values)
# ==============================================
# Routes Claude API calls through Vercel AI Gateway (bills Max subscription, not per-token)
# Get your token from: Vercel Dashboard → AI Gateway → link Anthropic subscription
# ANTHROPIC_BASE_URL="https://ai-gateway.vercel.sh"
# ANTHROPIC_API_KEY="your_vercel_ai_gateway_token"
# QA_MODEL="claude-haiku-4-5-20251001"   # use Haiku locally (cheap), Sonnet in CI
